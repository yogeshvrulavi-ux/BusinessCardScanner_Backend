# =============================================================================
# PRODUCTION — copy to `.env` on the API host (EC2), fill secrets, restart:
#   sudo systemctl restart business-card
# =============================================================================

# --- App ---
APP_ENV=production
HOST=0.0.0.0
PORT=5000
RELOAD=false

# --- Public URLs (invitation emails, PDF links, CORS) ---
FRONTEND_BASE_URL=https://www.namecardscan.com
BACKEND_BASE_URL=https://api.namecardscan.com
ALLOWED_ORIGINS=https://www.namecardscan.com,https://namecardscan.com
CORS_ORIGIN_REGEX=

# --- Database ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
CONTACT_STORAGE=postgresql

# --- JWT ---
JWT_SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET

# --- Business / brand (emails) ---
BUSINESS_COMPANY_NAME=NameCardScan
BUSINESS_EMAIL=REPLACE_WITH_FROM_EMAIL
BUSINESS_PHONE=
BUSINESS_WEBSITE=https://www.namecardscan.com

# --- SMTP ---
GMAIL_USER=REPLACE_WITH_SMTP_USER
GMAIL_APP_PASSWORD=REPLACE_WITH_APP_PASSWORD
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- AWS Textract ---
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
AWS_REGION=ap-south-1

# --- WhatsApp ---
WHATSAPP_APP_ID=REPLACE
WHATSAPP_ACCESS_TOKEN=REPLACE
WHATSAPP_GRAPH_API_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=REPLACE
WHATSAPP_BUSINESS_PHONE=REPLACE
WHATSAPP_BUSINESS_ACCOUNT_ID=REPLACE
WHATSAPP_APP_SECRET=REPLACE
WHATSAPP_VERIFY_TOKEN=REPLACE
WHATSAPP_CARD_RECEIVED_TEMPLATE_NAME=REPLACE
WHATSAPP_BUSINESS_CARD_TEMPLATE_NAME=REPLACE
WHATSAPP_SCAN_TEMPLATE_NAME=REPLACE
WHATSAPP_TEMPLATE_LANGUAGE_CODE=en
WHATSAPP_TEMPLATE_NAME=hello_world

# --- Bootstrap admin (change after first login) ---
SUPERADMIN_EMAIL=REPLACE
SUPERADMIN_PASSWORD=REPLACE

# --- Google Sheets (optional) ---
# GOOGLE_SHEET_ID=
# GOOGLE_SHEET_NAME=Contacts
# GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
