# Local development — copy to `.env` and adjust if needed.
# For production Amplify / EC2 values, use `.env.production.example` instead.

# --- App ---
APP_ENV=development
HOST=127.0.0.1
PORT=5000
RELOAD=true

# --- Public URLs ---
FRONTEND_BASE_URL=http://localhost:5173
BACKEND_BASE_URL=http://127.0.0.1:5000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?

# --- Database ---
DATABASE_URL=postgresql://postgres:PASSWORD@localhost:5432/cardsync_local?schema=public
CONTACT_STORAGE=postgresql

# --- JWT ---
JWT_SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET

# --- Business / brand ---
BUSINESS_COMPANY_NAME=NameCardScan
BUSINESS_EMAIL=
BUSINESS_PHONE=
BUSINESS_WEBSITE=

# --- SMTP ---
GMAIL_USER=
GMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- AWS Textract ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# --- WhatsApp ---
WHATSAPP_APP_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_GRAPH_API_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_PHONE=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_CARD_RECEIVED_TEMPLATE_NAME=
WHATSAPP_BUSINESS_CARD_TEMPLATE_NAME=
WHATSAPP_SCAN_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE_CODE=en
WHATSAPP_TEMPLATE_NAME=hello_world

SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
